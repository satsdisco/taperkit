{
  "name": "taperkit",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npx tsx server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "npm run build && npx tsx server/index.ts",
    "electron:dev": "vite build && tsc -p tsconfig.electron.json && electron .",
    "electron:build": "vite build && tsc -p tsconfig.server.json && printf '{\"type\":\"module\"}' > dist/server/package.json && tsc -p tsconfig.electron.json && electron-builder",
    "package": "npm run electron:build"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.6.0",
    "canvas": "^3.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "music-metadata": "^7.13.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.6",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.taperkit.app",
    "productName": "TaperKit",
    "asar": false,
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  }
}